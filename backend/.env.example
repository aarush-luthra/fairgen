# de.bias — Environment Variables

# ─── Local Development (API Key mode) ───────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# ─── GCP Deployment (ADC mode — replaces GOOGLE_API_KEY on Cloud Run) ───────
# When set, the backend switches to Application Default Credentials automatically.
# On Cloud Run: set this to your project ID in the --set-env-vars flag.
# Local:        run `gcloud auth application-default login` first.
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
